# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site
# docs/ - REMOVED: We want to track documentation files

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# === Kidsights Security & Data Protection ===

# API Keys and Credentials - NEVER COMMIT THESE!
*.csv
my-APIs/
*api*.csv
*token*.txt
*credential*.json
.env
.env.local

# Database files - protect participant data
*.db
*.duckdb
*.sqlite
*.sqlite3

# OneDrive and cloud storage paths
OneDrive*/
*OneDrive*/

# Logs that may contain sensitive data
logs/
*.log

# Cache and temporary files
cache/
tmp/
temp/
.cache/

# Data files - protect participant data
# Use data/* (not data/) so git descends into subdirs for per-file exception rules.
# Default stance: everything under data/ is ignored; each exception must be named explicitly.
data/*
!data/credi-mest_df.csv
!data/Zip_County_Code_UPDATED10.18.xlsx
# Allow descent into data/analyses/ so the single tracked README can be picked up.
# Everything else inside data/analyses/ is still ignored via data/analyses/* below.
!data/analyses/
data/analyses/*
*.rds
*.parquet
# MN26 NORC sampling-frame artifacts (no PII; needed by operators / future raking)
!data/mn26/
!data/mn26/id_xwalk.rds
!data/mn26/frame/
!data/mn26/frame/frame_child_demographic_summary.rds
!data/mn26/frame/frame_mother_demographic_summary.rds

# Codebook data - allow codebook.json but not backups
!codebook/data/
!codebook/data/codebook.json

# Personal configuration files
config/personal/
*personal*.yaml
*local*.yaml

# Test files and debugging artifacts
test_*.feather
test_*.R
*_test.R
debug_*.R

# Python cache
__pycache__/
*.pyc
*.pyo
*.py[cod]

# Stray files
nul

# Codebook backups (use git history instead)
codebook/data/codebook_pre_*.json
codebook/data/*_backup_*.json

# Temp scripts directory (but keep README)
scripts/temp/*.R
!scripts/temp/README.md

# Exports directory - contains sensitive SPSS/Stata files
exports/

# Goodsync metadata
_gsdata_/

# Build artifacts and output files
*.html
*.pdf
output/
R/authenticity_screening/

# Pages landing page — deliberately committed for GitHub Pages serving
!docs/index.html

# MN26 Quarto-rendered docs — single-file HTML (embed-resources: true).
# Re-render and re-commit alongside the .qmd source when the source changes.
!docs/mn26/pipeline_guide.html
!docs/mn26/pipeline_slides.html

# SES analytic data guide — single-file HTML (embed-resources: true).
# Re-render alongside the .qmd source when NE25 pipeline outputs change.
!docs/analyses/ses_analytic_data_guide.html

# data/analyses/README.md — maintainer-facing pointer in an otherwise-gitignored
# directory. The rest of data/analyses/ contains paper-specific datasets built
# from participant data and must remain ignored.
!data/analyses/README.md

# Todo archive artifacts
todo/archive.zip
todo/kidsights-calibration/
